               <msContents>
                  <summary>Two illustrated treatises on hunting compiled, apparently at the command
                     of Maharaja Dalip Singh, by one Dīn Muḥammad in around 1850. The first is on
                     birds of prey and their care and use. The second is on hunting with cheetahs
                     and lynxes.</summary>
                  <msItem xml:id="MS_Trinity_108-item1">
                     <locus from="1b" to="267b">Fol. 1b-267b</locus>
                     <author key="" role="com">
                        <persName xml:lang="ar-Latn-x-lc" type="standard">Dīn Muḥammad, fl. c.
                           1850</persName>
                        <persName xml:lang="ar">دين محمد</persName>
                     </author>
                     <title xml:lang="fa-Latn-x-lc" key="">Bāznāmah</title>
                     <title xml:lang="fa" key="">بازنامه</title>
                     <incipit xml:lang="fa">افتتاح ابواب سخن بنام مبدع حقیقی هنر است . . . اما بعد
                        بر رای حداقت برای طالبان این مذاق و تالیان این اوراق مخفی و محتجب
                        نمانده</incipit>
                     <explicit xml:lang="fa">که تمام سیر شکاری و اوستادی در تشخیصات مرض و مراح دانی
                        جانور است والله اعلم بالصواب</explicit>
                     <colophon xml:lang="fa">تمام شد</colophon>
                     <note/>
                     <note/>
                     <textLang mainLang="fa">Persian</textLang>
                     <listBibl>
                        <bibl/>
                     </listBibl>
                  </msItem>
                  <msItem xml:id="MS_Trinity_108-item2">
                     <locus from="267b" to="317a">Fol. 267b-317a</locus>
                     <author key="">
                        <persName xml:lang="ar-Latn-x-lc" type="standard">Dīn Muḥammad, fl. c.
                           1850</persName>
                        <persName xml:lang="ar">دين محمد</persName>
                     </author>
                     <title xml:lang="fa-Latn-x-lc" key="">Maqālah-'i thānavī dar tiyār (ṭiyār)
                        kardan-i yūz va siyāh gūsh</title>
                     <title xml:lang="fa" key="">مقاله ثانوی در تیار (طیار) کردن یوز و سیاه
                        گوش</title>
                     <incipit xml:lang="fa">متضمن بر نوزده باب باب اول در معرفت یوز وسیاه گوش مشتمل
                        بر دو فصل است</incipit>
                     <explicit xml:lang="fa">وقتیکه شکار تماشای موی مشغول شود برق انداز یا برنه شده
                        از عقب صید آمده تیر تیک زند مجرب است والله اعلم یالصواب</explicit>
                     <textLang mainLang="fa">Persian</textLang>
                     <listBibl>
                        <bibl/>
                     </listBibl>
                  </msItem>
               </msContents>

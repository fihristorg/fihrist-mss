               <msContents>
                  <summary/>
                  <msItem xml:id="MS_Trinity_110-item1">
                     <author key="person_60346321" ref="http://viaf.org/viaf/60346321">
                        <persName xml:lang="ar-Latn-x-lc" type="standard">Jazūlī, Muḥammad ibn
                           Sulaymān, ?-1465</persName>
                        <persName xml:lang="ar">الجزولي، محمد بن سليمان، 807-870 هـ</persName>
                     </author>
                     <title xml:lang="ar-Latn-x-lc" key="work_268">Dalāʼil al-khayrāt wa-shawāriq
                        al-anwār fī dhikr al-ṣalāt ʻalá al-nabī al-mukhtār</title>
                     <title xml:lang="ar" key="work_268">دلائل الخيرات وشوارق الأنوار في ذكر الصلوة
                        على النبي المختار</title>
                     <incipit xml:lang="ar">بسم الله الرحمن الرحيم صلى الله على سيدنا محمد وعلى آله
                        وصحبه وسلم الحمد لله الذى هدانا للايمان والاسلام ... وبعد هذا فالغرض في هذا
                        الكتاب ذكر الصلوة على النبي صلى الله عليه وسلم وفضائلها</incipit>
                     <explicit xml:lang="ar">وصلى الله على سيدنا محمد خاتم النبيين وإمام المرسلين
                        وعلى آله وصحبه وسلم تسليماً</explicit>
                     <colophon xml:lang="ar">تمت</colophon>
                     <note>Followed by the duʿāʾ (supplication) of completion.</note>
                     <textLang mainLang="ar">Arabic</textLang>
                     <listBibl>
                        <bibl>GAL II 252</bibl>
                     </listBibl>
                  </msItem>
               </msContents>

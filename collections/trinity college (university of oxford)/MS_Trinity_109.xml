               <msContents>
                  <summary>A copy of the Qurʼān copied in 1235 AH/1819-20 CE, possibly in
                     Istanbul</summary>
                  <msItem xml:id="MS_Trinity_109-item1">
                     <title xml:lang="ar-Latn-x-lc" key="work_112">al-Qurʼān</title>
                     <title xml:lang="ar" key="work_112">القرآن</title>
                     <colophon xml:lang="ar">صدق الله العظيم وصدق رسوله النبي الكريم ونحن على ذلك من
                        الشاهدين الشاكرين والحمد لله رب العالمين قد تشرف بتحرير هذا المصحف المجيد
                        والقران العظيم في يوم السبت مطابق سنة مائتين وخمس وثلثون بعد الألف من الهجرة
                        النبوية ألف ألف سلام والتحية عليه وعلى آله الطاهرين اللهم حرم في جسدنا نار
                        الجحيم برحمتك يا أرحم الراحمين في سنة ١٢٣٥</colophon>
                     <note>A complete copy.</note>
                     <textLang mainLang="ar">Arabic</textLang>
                     <listBibl>
                        <bibl/>
                     </listBibl>
                  </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="codex">
                     <supportDesc material="chart">
                        <extent>ff. i + 285 + i; folio 285 is blank.<dimensions type="leaf" unit="mm">
                              <height>180</height>
                              <width>100</width>
                           </dimensions></extent>
                     </supportDesc>
                     <layoutDesc>
                        <layout columns="1" ruledLines="16" n="mistara">One column throughout. Fols.
                           2b and 3a have six lines of text each per page; otherwise sixteen lines
                           per page. There are visible impressions of the misṭarah.<dimensions type="written" unit="mm">
                              <height>122</height>
                              <width>68</width>
                           </dimensions></layout>
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                     <handNote scope="major" script="naskh">
                        <desc><label>Script: </label>Small Naskh in black ink. Chapter headings in
                           red. Text is fully pointed. Recitation rules in red ink.</desc>
                     </handNote>
                  </handDesc>
                  <decoDesc>
                     <decoNote>Folios 1b and 2a decorated in gold and other colours with floral and
                        foliate designs in blue, green, gold, red, and pink. Text boxes are in gold
                        and black. Outer border in red ink.</decoNote>
                  </decoDesc>
                  <bindingDesc>
                     <p>Lacquer binding with flowers.</p>
                  </bindingDesc>
               </physDesc>

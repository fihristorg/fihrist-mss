               <history>
                  <origin change="#fix-dates">undated</origin>
                  <provenance when="1890">Received from <placeName key="place_7001354">Acre</placeName> on <date
                        when="1890-10-26">26 October 1890</date>, with a letter from <persName
                        key="person_88702713" role="fmo">Bahá'u'lláh</persName>'s son <persName
                        key="" role="dnr">Mírzá Badí'u'lláh</persName>, dated Ṣafar 18, AH 1308 (3
                     October 1890), explaining that the requested "Hidden Words" were not yet
                     ready, and that these Epistles were sent in the meantime.</provenance>
                  <acquisition when="1936">Passed to <placeName>Cambridge</placeName> University
                     Library in <date when="1936">1936</date> (the "Browne
                     Bequest").</acquisition>
               </history>

               <msContents>
                  <summary>A copy of the Persian <title xml:lang="fa-Latn-x-lc" key="work_499">Bayán</title>
                     (cf. <ref target="https://www.fihrist.org.uk/catalog/manuscript_578">F. 12 (BBP.
                        8)</ref>, a different copy of the same work). Browne refers the reader to his
                     own entry for BBP. 8 for a description of the work itself, confining this entry
                     to the manuscript's physical description and acquisition.</summary>
                  <msItem xml:id="F_13-item1">
                     <author key="person_9878408" ref="http://viaf.org/viaf/9878408/">
                        <persName xml:lang="ar-Latn-x-lc" type="standard">Bāb, ʻAlī Muḥammad Shīrāzī, 1819-1850</persName>
                        <persName xml:lang="en" key="person_9878408">the Bāb</persName>
                        <persName xml:lang="ar">باب، ميرزا علي محمد</persName>
                     </author>
                     <title xml:lang="fa-Latn-x-lc" key="work_499">Bayān-i farsī</title>
                     <title xml:lang="fa" key="work_499">بيان فرسى</title>
                     <incipit xml:lang="ar"/>
                     <explicit xml:lang="ar" defective="true"/>
                     <note>Ff. 4a-6a contain an index of contents. Browne describes the manuscript
                        as carefully and accurately written, and evidently collated, with
                        corrections and insertions in the margin.</note>
                     <listBibl>
                        <bibl>
                           <ref target="https://cudl.lib.cam.ac.uk/view/PR-A-00233-00004/85">p.59</ref>
                        </bibl>
                        <bibl>See sub classmark <idno>BBC. 3</idno> in Browne's "Catalogue and Description of 27 Bābī Manuscripts (Continuation)", in Journal of the Royal Asiatic Society of Great Britain and Ireland (Oct., 1892): 637-710.</bibl>
                        <bibl type="text-relations"/>
                     </listBibl>
                     <textLang mainLang="fa">Persian</textLang>
                  </msItem>
               </msContents>

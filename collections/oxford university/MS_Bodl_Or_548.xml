                  <summary change="#add-summary"> 1 copy of Zīj-i jadīd-i sulṭānī by Ulugh Beg,
                     1394-1449 </summary>
                  <msItem xml:id="MS_Bodl_Or_548-item1">
                     <author key="person_66844656" ref="http://www.viaf.org/viaf/66844656/">
                        <persName type="standard">Ulugh Beg, <date calendar="#Gregorian" from="1394"
                              to="1449">1394-1449</date>
                        </persName>
                        <persName xml:lang="ar">الغ بن شاهرخ، 796-853 هـ</persName>
                     </author>
                     <title xml:lang="fa-Latn-x-lc" key="work_3092">Zīj-i jadīd-i sulṭānī</title>
                     <title xml:lang="fa" key="work_3092">زیجِ جدیدِ سلطانی</title>
                     <incipit xml:lang="fa">بسم الله الرحمن الرحيم وبه نستعين تبارك الذي جعل في
                        السماء بروجا وجعل فيها سراجا و قمرا منيرا ... اما بعد چنین گوید اضعف عباد
                        الله واحوجهم الی الله المستعان الغ بیک بن شاهرخ بن تیمور گورگان احسن الله تع
                        احواله وانجح آماله </incipit>
                     <explicit xml:lang="fa">و چون این مدت بگذر ونوبت بآفتاب رسد و در مبداء تاریخ
                        ملکی پانصد و هشتاد سال از سالهای آن گذشته بوده است</explicit>
                     <listBibl>
                        <bibl>GAL II 213</bibl>
                        <bibl>[Ethé 1518 [not in Uri]]</bibl>
                     </listBibl>
                     <textLang mainLang="fa">Persian</textLang>
                  </msItem>
               </msContents>

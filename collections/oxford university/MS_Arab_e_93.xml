                  <msItem xml:id="MS_Arab_e_93-item1" n="1">
                     <locus from="3" to="25">ff. 3v-25r</locus>
                     <author key="person_f407">Anonymous</author>
                     <title xml:lang="ar-Latn-x-lc" key="work_4690">Jadwal faḍl al-dāʼir</title>
                     <title xml:lang="ar">جدول فضل الدائر</title>
                     <note>Astronomical tables</note>
                     <listBibl>
                        <bibl>Appendix Astronomy</bibl>
                        <bibl>[K. 210 (1).]</bibl>
                     </listBibl>
                     <textLang mainLang="ar">Arabic</textLang>
                  </msItem>

                  <msItem xml:id="MS_Arab_e_93-item2" n="2">
                     <locus from="27" to="33">ff. 27v-33r</locus>
                     <author key="person_78769310" ref="http://viaf.org/viaf/78769310/"
                        change="#ids-cleanup">
                        <persName type="standard" xml:lang="ar-Latn-x-lc">Kāshī, Jamshīd ibn
                           Masʻūd, <date calendar="#Gregorian" when="1436">d. ca. 1436</date>
                        </persName>
                        <persName xml:lang="ar"> جمشيد بن مسعود، ت. 823 ه </persName>
                     </author>
                     <title xml:lang="ar-Latn-x-lc" key="work_4691">Risālah fī istikhrāj jayb
                        darajah wāḥidah</title>
                     <title xml:lang="ar">رسالة في استخراج جيب درجة واحدة</title>
                     <incipit xml:lang="ar">بسم الله الرحمن الرحيم وبه نستعين احمده على جزيل انعامه
                        وحمد اكرامه واصلي على عباده الموحدين وحده واعلامه وعلى اله المهتدين بفيضه
                        والهامه وبعد</incipit>
                     <explicit xml:lang="ar"> وليختم الكلام فلهنا حامدين لولي الحمد ومصلين علي ٮٯ
                        وعلى اله الطٮن اجمعين والحمد لله رب العالمين. </explicit>
                     <listBibl>
                        <bibl>GAL II 211</bibl>
                        <bibl>[K 210 (2)]</bibl>
                     </listBibl>
                     <textLang mainLang="ar">Arabic</textLang>
                  </msItem>

                  <msItem xml:id="MS_Arab_e_93-item3" n="3">
                     <locus from="34" to="36">ff. 34v-36r</locus>
                     <author key="person_78769310" ref="http://viaf.org/viaf/78769310/"
                        change="#ids-cleanup">
                        <persName type="standard" xml:lang="ar-Latn-x-lc">Kāshī, Jamshīd ibn
                           Masʻūd, <date calendar="#Gregorian" when="1436">d. ca. 1436</date>
                        </persName>
                        <persName xml:lang="ar"> جمشيد بن مسعود، ت. 823 ه </persName>
                     </author>
                     <title xml:lang="ar-Latn-x-lc" key="work_4692">Maʻrifat samt al-qiblah bi-ʻamal
                        ṣināʻī</title>
                     <title xml:lang="ar">معرفة سمت القبلة بعمل صناعي</title>
                     <note>The ascription to Kāshī is Beestonʼs, not Kahleʼs</note>
                     <incipit xml:lang="ar">باسمة الاعلى في معرفة سمت القبلة وعبرنا من البلاد بطريق
                        صناعي اذا اردنا ذلك اردنا على سطح مستو في موازاة الافق دائرة</incipit>
                     <explicit xml:lang="ar">ليقطع خط حـ ط على نقطة ن عمود ن س على قطر ا هـ د ونفصل
                        منه ع س بقدر عمود ل م ونصل هـ ع ومخرجه فهو خط القبلة</explicit>
                     <listBibl>
                        <bibl>GAL II 211</bibl>
                        <bibl>[K 210 (3)]</bibl>
                     </listBibl>
                     <textLang mainLang="ar">Arabic</textLang>
                  </msItem>

                  <msItem xml:id="MS_Arab_e_93-item4" n="4">
                     <locus from="36" to="41">ff. 36v-41v</locus>
                     <author key="person_f407">Anonymous</author>
                     <title xml:lang="ar-Latn-x-lc" key="work_4693">Risālah fī al-ʻamal bil-rubʻ
                        al-jāmiʻ</title>
                     <title xml:lang="ar">رسالة في العمل بالربع الجامع</title>
                     <incipit xml:lang="ar">[بغير] بسم الله الرحمن الرحيم الحمد لله الذي خلق السموات
                        من غير عمود والصلوة على رسوله المرتفع في المقنطرات الصعود وعلى اله السالكين
                        في السمت القويم واصحابه المهتدين في الطريق المستقيم وبعد</incipit>
                     <explicit xml:lang="ar">الحمد لله على التمام والصلوة والسلام على الرسول الكريم
                        وعلى آله وأصحابه العظام</explicit>
                     <listBibl>
                        <bibl>Appendix Astronomy</bibl>
                        <bibl>[K 210 (4)]</bibl>
                     </listBibl>
                     <textLang mainLang="ar">Arabic</textLang>
                  </msItem>

                  <msItem xml:id="MS_Arab_e_93-item5" n="5">
                     <locus from="43" to="45">ff. 43v-45v</locus>
                     <author key="person_90045995" ref="http://viaf.org/viaf/90045995/">
                        <persName type="standard" xml:lang="ar-Latn-x-lc">Taqī al-Dīn Muḥammad
                           ibn Maʻrūf, <date calendar="#Gregorian" from="1525" to="1585">1525 or
                              6-1585</date>
                        </persName>
                        <persName xml:lang="ar">ابن معروف، محمد، 932-993 هـ</persName>
                     </author>
                     <title xml:lang="ar-Latn-x-lc" key="work_4694">Risālah fī al-ʻamal bil-rubʻ
                        al-Shikkāzī</title>
                     <title xml:lang="ar">رسالة في العمل بالربع الشكّازي</title>
                     <note>*Para. 6 has been dropped from G2, hence nos. 1-3 and 5 of Asadīʼs works
                        appear in edn. 1. only.</note>
                     <note>*H. Khal III 401, cf. Suber 471.</note>
                     <incipit xml:lang="ar">بسم الله الرحمن الرحيم الحمد لله للحق حمده وصلوته على
                        خير خلقه محمد رسوله وعبده وعلى آله وصحبه من بعده وسلم وشرف وكرم وبعد فهذه
                        رسالة وجيزة مفيدة في العمل الربع الشكازي تشتمل على عشرة أبواب </incipit>
                     <explicit xml:lang="ar">وقصدنا الاختصار والله الموفق سبحانه وتعالى عما يقولون
                        علوا كبيرا وصل الله على سيدنا محمد وعلى اله واصحابه الطاهرين وسلم تسليما
                        كثيرا كثيرا</explicit>
                     <listBibl>
                        <bibl>GAL II 357-358</bibl>
                        <bibl>[K. 210 (5)]</bibl>
                     </listBibl>
                     <textLang mainLang="ar">Arabic</textLang>
                  </msItem>

                  <msItem xml:id="MS_Arab_e_93-item6" n="6">
                     <locus from="45" to="47">ff. 45v-47r</locus>
                     <author key="person_21961933" ref="http://viaf.org/viaf/21961933">
                        <persName xml:lang="ar-Latn-x-lc" type="standard">Ibn al-Sarrāj, Aḥmad ibn
                           Abī Bakr, <date calendar="#Gregorian" notBefore="1300" notAfter="1400"
                              >14th cent.</date>
                        </persName>
                        <persName xml:lang="ar">ابن السراج، أحمد بن أبي بكر</persName>
                     </author>
                     <title xml:lang="ar-Latn-x-lc" key="work_4695">Risālah Jayl al-ghāʼib</title>
                     <title xml:lang="ar">رسالة جيل الغائب</title>
                     <note>[= Brock. no. 1?]</note>
                     <incipit xml:lang="ar">اللهم صل على سيدنا محمد واله أجمعين رسالة جيب الغايب قال
                        ابن السراج رحمه الله قد فتح الله على توهم تسطيح الكرة وتوهم مقاطع الداير
                        العظام و غيرها على سطحها وترميم [?] اوتارها في سطوحها وامعنت النظر في
                        الاوتار والجيوب وخواصها ولوازمها</incipit>
                     <explicit xml:lang="ar">وانقل الخيط الى خط الاستواء فما قطع الموري من دواير
                        التعديل فهو فضل الداير والا فاترك مع الجيوب المنكوسة الى القوس تجد فصل
                        الداير من اول</explicit>
                     <listBibl>
                        <bibl>GAL II 126</bibl>
                        <bibl>[K 210 (6)]</bibl>
                     </listBibl>
                     <textLang mainLang="ar">Arabic</textLang>
                  </msItem>

                  <msItem xml:id="MS_Arab_e_93-item7" n="7">
                     <locus from="47" to="49">ff. 47v-49v</locus>
                     <author key="person_f3988">
                        <persName xml:lang="ar-Latn-x-lc">Shādhilī, Aḥmad ibn ʻUmar</persName>
                        <persName xml:lang="ar">الشاذلي، أحمد بن عمر</persName>
                     </author>
                     <title xml:lang="ar-Latn-x-lc" key="work_4696">Risālah [al-]Rubʻ
                        [al-]Shikkāzī</title>
                     <title xml:lang="ar">رسالة في العمل بالربع الشكّازي</title>
                     <incipit xml:lang="ar">بسم الله الرحمن الرحيم وهو حسبي الحمد لله حق حمده
                        وصلواته على محمد خير خلقه وعلى آله وصحبه من بعده وبعد</incipit>
                     <explicit xml:lang="ar">والله أعلم والحمد لله وحده وصلواته على سيدنا محمد وآله
                        أجمعين</explicit>
                     <listBibl>
                        <bibl>Appendix Astronomy</bibl>
                        <bibl>[K 210 (7)]</bibl>
                     </listBibl>
                     <textLang mainLang="ar">Arabic</textLang>
                  </msItem>


                  <msItem xml:id="MS_Arab_e_93-item8" n="8">
                     <locus from="56" to="56">f. 56v</locus>
                     <author key="person_f407">Anonymous</author>
                     <title xml:lang="ar-Latn-x-lc" key="work_4697">Risālah fī maʻrifah waḍʻ inṣāf
                        aqṭār</title>
                     <listBibl>
                        <bibl>Appendix Astronomy</bibl>
                        <bibl>[K 210 (9)]</bibl>
                     </listBibl>
                     <textLang mainLang="ar">Arabic</textLang>
                  </msItem>

                  <msItem xml:id="MS_Arab_e_93-item9" n="9">
                     <locus from="57" to="60">ff. 57r-60v</locus>
                     <note>Fols. 53-56a are in Persian and seem to dicuss complex astronomical and
                        mathematical divisions</note>
                     <note>Fol. 56b is a singular page in Arabic titled <note xml:lang="ar">في معرفة
                           وضع أنصاف أقطار</note></note>
                     <author key="person_f407">Anonymous</author>
                     <title xml:lang="ar-Latn-x-lc" key="work_4698">ʻAmal ruʼūs al-kawākib
                        al-thābitah fī al-ʻankabūt</title>
                     <title xml:lang="ar">عمل رؤوس الكواكب الثابتة في العنكبوت</title>
                     <incipit xml:lang="ar">عمل رؤس الكواكب الثابتة في العنكبوت اما الاول فليس ممكن
                        الا بعد معرفة ابعاد الكواكب الثابتة عن معدل النهار ويسمى البعد الحق وعن
                        الجزء الذي يتوسط السماء معها من فلك البروج ويسمى درجة الممر</incipit>
                     <explicit xml:lang="ar"> واقسم ايضا ٨٠٠ على جيب مجموع القسم الاول والقسم ٢ من
                        الاقسام الستة فما خرج فهو بعد مركز الساعة ٢ عن مركز الربع وعلى هذا
                        المنهاج</explicit>
                     <listBibl>
                        <bibl>Appendix Astronomy</bibl>
                        <bibl>[K 210 (10)]</bibl>
                     </listBibl>
                     <textLang mainLang="ar">Arabic</textLang>
                  </msItem>

                  <msItem xml:id="MS_Arab_e_93-item10" n="10">
                     <locus from="61" to="64">ff. 61v-64r</locus>
                     <author key="person_f407">Anonymous</author>
                     <title xml:lang="ar-Latn-x-lc" key="work_4699">Risālah [al-]Rubʻ
                        al-mujannaḥ</title>
                     <title xml:lang="ar">رسالة الربع المجنح</title>
                     <incipit xml:lang="ar">فهذه الآلة تسمى بالربع المجنح في نسخة الرسوم المركز وهو
                        الثقب الذي هو الخط ويسمى أيضا القطب قوس الارتفاع هو القوس المقوم ص جزا
                        مساوية</incipit>
                     <note>On fol. 63 the language shifts to Persian.</note>
                     <explicit xml:lang="ar">افزودیم حاصل آمد [نط ند] در جدول مطالع ثانی مقوس ساختیم
                        بیرون آمد طالع [ب ٮه ٮٮ] وعلى ذلك القياس</explicit>
                     <listBibl>
                        <bibl>Appendix Astronomy</bibl>
                        <bibl>[K 210 (11)]</bibl>
                     </listBibl>
                     <textLang mainLang="ar">Arabic</textLang>
                  </msItem>
               </msContents>


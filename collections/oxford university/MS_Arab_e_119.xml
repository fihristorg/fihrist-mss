               <msContents class="#multipleWorks">
                  <summary change="#add-summary2">8 works by 6 authors on the subjects of
                     Astronomical instruments, Astronomy, and Mathematics </summary>
                  <msItem xml:id="MS_Arab_e_119-item1" n="1">
                     <locus from="1" to="9">fols. 1b-9b</locus>
                     <author key="person_56597947" ref="http://www.viaf.org/viaf/56597947/">
                        <persName type="standard" xml:lang="ar-Latn-x-lc">Sibṭ al-Māridīnī, Badr
                           al-Dīn Muḥammad ibn Muḥammad, b. <date calendar="#Gregorian"
                              when="1423">1423</date>
                        </persName>
                        <persName xml:lang="ar">سبط المارديني، محمد بن محمد، 826-912 هـ</persName>
                     </author>
                     <title xml:lang="ar-Latn-x-lc" key="work_5122">R. fī al-ʻamal bil-rubʻ
                        al-mujayyab</title>
                     <title xml:lang="ar">رسالة في العمل بالربع المجيب</title>
                     <incipit xml:lang="ar">بسم الله الرحمن الرحيم وبه نستعين الحمد الله رب العالمين
                        والصلوة والسلام على سيدنا محمد واله اجمعين وبعد فهذه رسالة في العمل بالربع
                        المجيب مشتملة على مقدمة وعشرين بابا </incipit>
                     <explicit xml:lang="ar">هذه اخره والله اعلم بكل الامور والحمد لله اولاً واخراً
                        والصلاوة على رسوله محمد واله اجمعين</explicit>
                     <colophon xml:lang="ar">تمت الرسالة المسمي بالربع المجيّب على يد أحقر الطلاب
                        احمد بن خليل سنة ١ ١١٣</colophon>
                     <listBibl>
                        <bibl>GAL II 167</bibl>
                        <bibl>[K 228 (1)]</bibl>
                     </listBibl>
                     <textLang mainLang="ar">Arabic</textLang>
                  </msItem>
                  <msItem xml:id="MS_Arab_e_119-item2" n="2">
                     <locus from="10" to="24">fols. 10b-24a</locus>
                     <author key="person_56597947" ref="http://www.viaf.org/viaf/56597947/">
                        <persName type="standard" xml:lang="ar-Latn-x-lc">Sibṭ al-Māridīnī, Badr
                           al-Dīn Muḥammad ibn Muḥammad, b. <date calendar="#Gregorian"
                              when="1423">1423</date>
                        </persName>
                        <persName xml:lang="ar">سبط المارديني، محمد بن محمد، 826-912 هـ</persName>
                     </author>
                     <title xml:lang="ar-Latn-x-lc" key="work_9881" change="#ids-cleanup">Hidāyat
                        al-ʻāmil [bil-rubʻ al-kāmil]</title>
                     <title xml:lang="ar">هداية العامل بالربع الكامل</title>
                     <incipit xml:lang="ar">بسم الله الرحمن الرحيم الحمد الله الذي رسم في صفحات
                        مصنوعاته قواطع الدلائل وسير الكواكب الثابتة في محيط الآفاق تهتدي بها في
                        الطوالع منها والاوافل</incipit>
                     <explicit xml:lang="ar">فاجمع غايته السفلي لتمام بعده كما سبق وتمام غايته
                        العليا لبعده يحصل العرض فيها وفي هذا القدر كفاية لمن وفقه الله تعالى</explicit>
                     <colophon xml:lang="ar">تمت رسالة المقنطرات بعون الله الملك الوهاب. على يد أضعف العباد احمد بن خليل
                        غفر الله له ولوالديه واحسن اليهما واليه سنه ١١٣١ </colophon>
                     <listBibl>
                        <bibl>GAL II 168</bibl>
                        <bibl>[K 228 (2)]</bibl>
                     </listBibl>
                     <textLang mainLang="ar">Arabic</textLang>
                  </msItem>
                  <msItem xml:id="MS_Arab_e_119-item3" n="3">
                     <locus from="29" to="46">ff. 29b-46b</locus>
                     <author key="person_f407">Anonymous</author>
                     <title xml:lang="ar-Latn-x-lc" key="work_5124">R. fī al-asṭurlāb al-shimālī
                        dhāt al-ṣafāʼiḥ</title>
                     <title xml:lang="ar">رسالة في الأسطرلاب الشمالي ذات الصفائح</title>
                     <note>In a muqaddimah and 15 chapters; identical with Ahlwardt 5810, 5811; cf.
                        also Princeton 1020, 20265</note>
                     <incipit xml:lang="ar"> بسم الله الرحمن الرحيم الحمد الله حمداً يليق بجلاله
                        والصلاة والسلام على خير خلقه محمد وآله وصحبه وبعد فهذه رسالة مختصرة اذكر
                        فيها اسماء الرسوم المرسومة على الآلة المسماة بالاسطرلاب الشمالي ذات الصفايح
                        وبعض اعمالها وهي مشتملة على مقدمة وخمسة عشر فصلا وخاتمة</incipit>
                     <explicit xml:lang="ar">والله تعالى اعلم حقيقة الحال وإليه المرجع والمال ثم
                        كتابة الكتاب بعون الله الملك الوهاب</explicit>
                     <note> In fols. 46 (from line 9 approx.) - 48, the language shifts to Ottoman
                        Turkish. </note>
                     <listBibl>
                        <bibl>Appendix Astronomy</bibl>
                        <bibl>[K 228 (3)]</bibl>
                     </listBibl>
                     <textLang mainLang="ar">Arabic</textLang>
                  </msItem>
                  <msItem xml:id="MS_Arab_e_119-item4" n="4">
                     <locus from="49" to="54">ff. 49r-54v</locus>
                     <author key="person_f168">
                        <persName xml:lang="ar-Latn-x-lc">Abū Saʻīd al-Mughrib</persName>
                        <persName xml:lang="ar">أبو سعيد المغرب</persName>
                     </author>
                     <title key="work_5125">[A work on multiplication]</title>
                     <incipit xml:lang="ar">بسم الله الرحمن الرحيم قال الشيخ الامام الاجل الزاهد ابو
                        سعيد المغرب رحمة الله عليه اعلم ان ما يتعامل به الناس ثلثة انواع موزون ومكيل
                        وم[رج؟]وح وجميع ذلك لا يستغني عن العدد وللعدد اربع م[نا؟]زل آحاد وعشرات ومآت
                        والوف </incipit>
                     <explicit xml:lang="ar">تمت الرسالة بعون الله الملك المنان وللرسول افضل الصلوة
                        والسلام تمام اولدي</explicit>
                     <listBibl>
                        <bibl>Appendix Mathematics</bibl>
                        <bibl>[K 228 (5)]</bibl>
                     </listBibl>
                     <textLang mainLang="ar">Arabic</textLang>
                  </msItem>
                  <msItem xml:id="MS_Arab_e_119-item5" n="5">
                     <locus from="55" to="70">fols. 55-70</locus>
                     <author key="person_314809464" change="#ids-cleanup">
                        <persName xml:lang="ar-Latn-x-lc" type="standard"
                           ref="http://viaf.org/viaf/314809464/" change="#ids-cleanup">Sanbāṭī,
                           Aḥmad ibn ʻAbd al-Ḥaqq, <date calendar="#Gregorian" notBefore="1500"
                              notAfter="1600">16th cent.</date>
                        </persName>
                        <persName xml:lang="ar">‏سنباطي، أحمد بن أحمد بن عبد الحق</persName>
                     </author>
                     <title key="work_5126">Commentary on <title xml:lang="ar-Latn-x-lc">al-Risālah
                           fī al-ʻamal bil-rubʻ al-mujayyab</title> of <persName
                           xml:lang="ar-Latn-x-lc" type="standard" key="person_56597947"
                           ref="http://viaf.org/viaf/56597947/" xml:id="m2" role="ant"
                           change="#role-assignment">Sibṭ al-Māridīnī, Badr al-Dīn Muḥammad
                           ibn Muḥammad, b. <date calendar="#Gregorian" when="1423">1423</date>
                        </persName>
                     </title>
                     <title xml:lang="ar">شرح رسالة في العمل بالربع المجيب لسبط المارديني</title>
                     <incipit> بسم الله الرحمن الرحيم وبه نستعين وصلى الله على سيدنا محمد خاتم
                        النبيين والمرسلين وعلي اله الطيبين الطاهرين وصحابته اجمعين وبعد </incipit>
                     <explicit xml:lang="ar"> والله أعلم بالصواب وإليه المرجع والمأب وصلى الله على
                        سيدنا محمد وعلى آله وصحبه وسلم والحمد لله رب العالمين</explicit>
                     <colophon xml:lang="ar"> كان الفراغ من كتابة هذا الشرح يوم الخميس المبارك يوم
                        ثاني شهر جماد[ى] الآخر من سنة ١٠٨٧ على يد الفقير إلى الله تعالى إبراهيم بن
                        محمد علي بن ولي البخاري غفر الله له ولوالديه</colophon>
                     <listBibl>
                        <bibl>GAL II 168</bibl>
                        <bibl>[K 228 (6)]</bibl>
                     </listBibl>
                     <textLang mainLang="ar">Arabic</textLang>
                  </msItem>
                  <msItem xml:id="MS_Arab_e_119-item6" n="6">
                     <locus from="73" to="102">ff. 73v-102r</locus>
                     <author key="person_8594501" ref="http://viaf.org/viaf/8594501/">
                        <persName type="standard" xml:lang="ar-Latn-x-lc">Shillī, Muḥammad ibn
                           Abī Bakr, <date calendar="#Gregorian" from="1620" to="1682">1620 or
                              21-1681 or 2</date>
                        </persName>
                        <persName xml:lang="ar">الشلي، محمد بن أبي بكر، 1030-1093 هـ</persName>
                     </author>
                     <title xml:lang="ar-Latn-x-lc" key="work_5127">Risālat al-ʻAmal bil-rubʻ
                        al-mujayyab</title>
                     <title xml:lang="ar">رسالة العمل بالربع المجيب</title>
                     <note>With a commentary by the author</note>
                     <incipit xml:lang="ar">بسم الله الرحمن الرحيم الحمد الله الذي اطلع في سما[ء]
                        العلوم شموسا وبدورا وجعل الشمس ضياءً وزين السما[ء]بنجوم يهتدي بها في
                        الظلمات، ويعرف بها اوقات الصلوات، واشهد ان لا اله الا الله وحده لا شريك له
                        واشهد ان سيدنا محمدا افضل نبي ارسله وبعد</incipit>
                     <explicit xml:lang="ar">ختمت الرسالة بالصلاة على النبي صلي الله عليه وسلم
                        والحمد لله كما بدت بهما وجآ[ء] قبول ما بينهما وليكن هذا اخر ما اردناه من هذا
                        التعليق المبارك ونسال الله تعالى ان ينتفع به كاتبه وقاريه والناظر اليه فهو
                        حسبي ونعم الوكيل ولا حول ولا قوة الا بالله العلي العظيم وصلى الله على سيدنا
                        محمد وعلى اله وصحبه وسلم تسليماً كثيرا</explicit>
                     <listBibl>
                        <bibl>GAL II 383</bibl>
                        <bibl>[K 228 (7)]</bibl>
                     </listBibl>
                     <textLang mainLang="ar">Arabic</textLang>
                  </msItem>
                  <msItem xml:id="MS_Arab_e_119-item7" n="7">
                     <locus from="103" to="138">ff. 103v-138r</locus>
                     <author key="person_314817490" ref="http://viaf.org/viaf/68777659/"
                        change="#ids-cleanup">
                        <persName xml:lang="ar-Latn-x-lc">Maghribī, Muḥammad ibn Muḥammad ibn
                           Sulaymān, <date calendar="#Gregorian" when="1683">d. 1683</date>
                        </persName>
                        <persName xml:lang="ar">الروداني، محمد بن سليمان، 1037-1094 هـ</persName>
                     </author>
                     <title xml:lang="ar-Latn-x-lc" key="work_5128">al-Nāfiʻah fī aʻmāl
                        al-jāmiʻah</title>
                     <title xml:lang="ar">النافعة في أعمال الجامعة</title>
                     <note>On astronomy</note>
                     <incipit xml:lang="ar">بسم الله الرحمن الرحيم وصلى الله على سيدنا محمد وآله
                        وصحبه وسلم وحسبنا الله ونعم الوكيل ان ازهى ما تجلى لبصاير العقول من آوجات
                        عوالم الالهام وابهى ما تحلى بمشاهر عرفانه دواير النفوس وطوا[؟] الافهام حمد
                        من تحجب في سرادقات الكبريا بسبحات عزه ومجده</incipit>
                     <explicit xml:lang="ar">والله اعلم وحسبنا الله ونعم الوكيل ولا حول ولا قوة الا
                        بالله العلي العظيم وصلى الله عاى سيدنا محمد وآله وصحبه وسلم</explicit>
                     <listBibl>
                        <bibl>Appendix Astronomy</bibl>
                        <bibl>[K 228 (8)]</bibl>
                     </listBibl>
                     <textLang mainLang="ar">Arabic</textLang>
                  </msItem>
                  <msItem xml:id="MS_Arab_e_119-item8" n="8">
                     <locus from="139" to="142">ff. 139v-142v</locus>
                     <author key="person_f407">Anonymous</author>
                     <title xml:lang="ar-Latn-x-lc" key="work_5129">R. fī al-ʻamal bil-kurah</title>
                     <title xml:lang="ar">رسالة في العمل بالكرة</title>
                     <incipit xml:lang="ar">بسم الله الرحمن الرحيم وبه نستعين ونكتفي الحمد الله رب
                        العالمين والصلاة على نبيه محمد خاتم النبيين محمد وآله وصحبه الطاهرين
                        المنتخبين وبعد</incipit>
                     <explicit xml:lang="ar">ويكفي من هذه الرسالة العمل تلك الآلة والله سبحانه
                        وتعالى ملهم للصواب وليه المرجع والمآب وصلى الله على سيدنا محمد وعلى آله
                        وصحبه وسلم تسليماً كثيرا </explicit>
                     <listBibl>
                        <bibl>Appendix Astronomy</bibl>
                        <bibl>[K 228 (9)]</bibl>
                     </listBibl>
                     <textLang mainLang="ar">Arabic</textLang>
                  </msItem>
               </msContents>

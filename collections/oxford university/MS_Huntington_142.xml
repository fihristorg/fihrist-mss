               <msContents>
                  <summary change="#add-summary"> 1 copy of al-Tabṣirah fī ʻilm al-hayʼah by
                     Kharaqī, ʻAbd al-Jabbār ibn ʻAbd al-Jabbār, 1084-1158 </summary>
                  <msItem xml:id="MS_Huntington_142-item1">
                     <author key="person_90056192" ref="http://viaf.org/viaf/90056192/">
                        <persName type="standard" xml:lang="ar-Latn-x-lc">Kharaqī, ʻAbd al-Jabbār
                           ibn ʻAbd al-Jabbār, <date calendar="#Gregorian" from="1084" to="1158"
                              >1084-1158</date>
                        </persName>
                        <persName xml:lang="ar">الخرقي، عبد الجبار بن عبد الجبار، 477-553 هـ</persName>
                     </author>
                     <title xml:lang="ar-Latn-x-lc" key="work_3489">al-Tabṣirah fī ʻilm
                        al-hayʼah</title>
                     <title xml:lang="ar" key="work_3489">التبصرة في علم الهيئة</title>
                     <note>with a few marginal notes in a diff. hand</note>
                     <incipit xml:lang="ar">بسم الله الرحمن الرحيم رب يسّر الحمد لله حق حمده والصلوة
                        على خير خلقه محمد سيّد اصفيايه وخاتم انبيايه وبعد فان العلماء والحكماء كانوا
                        قبل زماننا هذا متوفرين على جمع العلوم وتاليفها وايضاحها وتلخيصها اذ كانت
                        اوقاتهم صافيه عن الشواغل والشوايب </incipit>
                     <explicit xml:lang="ar">والمنجمون يقسمون كل ساعة من الساعات ستين قسماً يسمى كل
                        قسم منها دقيقة على ما جرت عادتهم في قسمة الدرج واجزائها بالاجزاء الستينية
                        وحين انتهينا الى ها هنا فلنختم هذا الكتاب بهذا الباب والحمد لله رب العالمين
                        وصلواته على محمد نبيه وآله الطاهرين وسلم تسليماً </explicit>
                     <colophon xml:lang="ar">تمت التبصرة في الهيئة تاليف بهاء الدين أبي محمد الخرقي
                        ووافق الفراغ في شهر جمادي الاول سنة ثمان وتسعين وستمائة هجرية ه وحسبنا الله
                        ونعم الوكيل نعم المولى ونعم النصير</colophon>
                     <listBibl>
                        <bibl>GAL I 473</bibl>
                        <bibl>[UAM. 911 with corrig. Nicoll p. 600; revd. Beeston]</bibl>
                     </listBibl>
                     <textLang mainLang="ar">Arabic</textLang>
                  </msItem>
               </msContents>

                    <msContents>
                        <summary> This volume features the Arabic devotional work <title
                                key="work_268">Dalā'il al-Khayrāt</title> by <persName
                                xml:lang="fa-Latn-x-lc" key="person_90770167">Muḥammad ibn Sulaymān
                                al-Jazūlī (d. 1465)</persName>, with an anonymous interlinear
                            translation into Persian, with lavishly illuminated headpieces and
                            depictions of the holy sites in Mecca and Madina placed towards the end
                            of the second part. Unsigned and undated unidentified scribe possibly
                            completed it in <placeName ref="http://vocab.getty.edu/page/tgn/7000208"
                                key="place_7000208">Indian subcontinent</placeName> in the <date
                                cert="medium" calendar="#Gregorian" notBefore="1700" notAfter="1800"
                                >18th century CE</date>.</summary>
                        <msItem xml:id="Hart_21174-item1" n="1">
                            <title key="work_268">Dalā'il al-Khayrāt</title>
                            <title xml:lang="fa">دلائل الخيرات</title>
                            <author key="person_60346321" ref="https://viaf.org/viaf/31876500/">
                                <persName xml:lang="fa-Latn-x-lc">al-Jazūlī, Muḥammad ibn Sulaymān,
                                    d. 1465</persName>; <lb/>
                                <persName xml:lang="ota">الجزولي، محمد ابن سليمان</persName>
                            </author>
                            <editor role="trl" key="f407"><persName>Anonymous</persName></editor>

                            <textLang mainLang="ar" otherLangs="fa">Arabic and Persian</textLang>

                        </msItem>

                    </msContents>


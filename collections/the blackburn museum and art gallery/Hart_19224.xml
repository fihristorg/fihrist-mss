                    <msContents>
                        <summary> The <title key="work_10180">Dīvān-ı Rāġıb</title> of Ottoman poet
                                <persName xml:lang="fa-Latn-x-lc" key="person_90770167">Koca Ragıb
                                Paşa (ca. 1698–1763)</persName> features a lavishly illuminated
                            opening and depiction of a rose at the conclusion. An unidentified
                            scribe completed it in <placeName
                                ref="http://vocab.getty.edu/page/tgn/7706483" key="place_7706483"
                                >Güzelhısar (Aydın)</placeName> on <date calendar="#Hirji-qamari"
                                from="1749" to="1750">1163 AH (1749–1750 CE)</date> during the
                            author's lifetime.</summary>
                        <msItem xml:id="Hart_19223-item1" n="1">
                            <title key="work_10180">Dīvān-ı Rāġıb</title>
                            <title xml:lang="fa">دیوان راغب</title>
                            <author key="person_31876500" ref="https://viaf.org/viaf/31876500/">
                                <persName xml:lang="fa-Latn-x-lc">Meḥmed Rāġıb Pāşā, ca.
                                    1698–1763</persName>; <lb/>
                                <persName xml:lang="ota">محمد راغب پاشا</persName>
                            </author>
                            <incipit xml:lang="fa"> حضرت پادشاه علی الاطلاق عزت كلمته و جلت عظمته
                                منشور دولت سلطان المرسلين و متمم اخلاق المحسنين محمد النبي الامي الا
                                مين را صلوات الله  و سلامه علیه و اله اجمعین بطغرای غرای
                                «[وَ]إِنَّكَ لَعَلى خُلُقٍ عَظِيمٍ» مرتفع و مزین کردانید زیرا که جسن
                                خلق نوریست از انوار حکمت آلهی… </incipit>
                            <colophon> Completed in <placeName
                                    ref="http://vocab.getty.edu/page/tgn/7706483" key="place_7706483"
                                    >Güzelhısar (Aydın)</placeName> on <date calendar="#Hirji-qamari" from="1749"
                                    to="1750">1163 AH (1749–1750 CE)</date>. </colophon>

                            <textLang mainLang="ota" otherLangs="fa">Ottoman Turkish and
                                Persian</textLang>

                        </msItem>

                    </msContents>

                    <physDesc>

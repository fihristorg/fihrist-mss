                                        <dimensions type="illustration" unit="mm">
                                            <height>223</height>
                                            <width>132</width>
                                        </dimensions>
                                    </item>
                                    <lb/>
                                    <item n="4"><title>Majnūn in the wilderness</title>.<lb/>
                                        <dimensions type="illustration" unit="mm">

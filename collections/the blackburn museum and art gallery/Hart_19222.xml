                    <msContents>
                        <summary>This extensively illustrated manuscript features three of five
                            tales, the <title>Makhzan al-Asrār</title> (Treasury of Secrets),
                            romance of <title>Laylà va Majnūn</title>, and <title>Haft
                                Paykar</title> (Seven Portraits) from the <title>Khamsah</title>
                            (Quintet) by <persName>Niẓāmī Ganjavī (ca. 1140–1203)</persName>.
                            Originally composed as separate books bound together, each tale opens
                            with an illuminated headpiece.</summary>
                        <msItem xml:id="Hart_19222-item1">
                            <author key="person_2474895" ref="http://viaf.org/viaf/2474895/">
                                <persName xml:lang="fa-Latn-x-lc" type="standard">Niẓāmī Ganjavī,
                                    ca. 1140–1203</persName>
                                <persName xml:lang="fa">نظامى گنجوى</persName>
                            </author>
                            <title xml:lang="fa-Latn-x-lc" key="work_20054">Khamsah</title>
                            <title xml:lang="fa" key="work_20054">خمسۀ</title>
                            <msItem xml:id="Hart_19222-item1_item1">
                                <title key="work_3764">Makhzan al-Asrār</title>
                            </msItem>
                            <msItem xml:id="Hart_19222-item1_item2">
                                <title key="work_20432">Laylà va Majnūn</title>
                            </msItem>
                            <msItem xml:id="Hart_19222-item1_item3">
                                <title xml:lang="fa" key="work_4361">Haft Paykar</title>

                            </msItem>
                            <textLang mainLang="fa">Persian</textLang>
                            <note>For another copy of tales by the same poet in the The Blackburn
                                Museum &amp; Art Gallery, see <ref
                                    target="https://www.fihrist.org.uk/catalog/manuscript_19949"
                                        ><idno>Hart 19223</idno></ref>.</note>
                        </msItem>

                    </msContents>


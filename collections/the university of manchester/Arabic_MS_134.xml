                    <history>
                        <origin/>
                        <provenance>It was brought from Aleppo by <name role="fmo"
                                key="person_18003738"><persName>Dr Patrick
                            Russell</persName></name>, physician and naturalist who worked in
                            Aleppo, Syria and in the Madras Province of India. Dr P. Russell
                            bequeathed it to Mr C. Russell's sons in 1805; see note on the <locus
                                from="Front_paste-down">front paste-down</locus>: <quote>Bequeath'd
                                by Dr Patrick Russell to Mr C. Russell's sons
                            1805</quote></provenance>
                        <provenance>
                            <p>Formerly part of the collection of the Persian scholar <persName
                                    type="standard"
                                    ref="http://viaf.org/viaf/20108923/#Bland,_Nathaniel,_1803-1865"
                                    key="person_20108923" role="fmo">Nathaniel Bland
                                    (1803-1865)</persName>. His bookplate on the <locus
                                    from="Back_paste-down">back paste-down</locus>: "Bland MSS
                                213".</p></provenance>
                        <provenance><p>Bland’s oriental manuscripts were sold through <persName
                                    key="person_5679225" role="bsl">Bernard Quaritch</persName> in
                                1866 to <persName type="standard"
                                    ref="http://viaf.org/viaf/97751058/" key="person_97751058"
                                    role="fmo">Alexander Lindsay, 25th Earl of
                                Crawford</persName>.</p>
                        </provenance>
                        <provenance><p>Purchased by <name role="dnr" key="person_f6379">
                                    <persName type="display">Enriqueta Rylands
                                        (1843–1908)</persName>
                                    <persName type="standard"> Rylands, Enriqueta,
                                        1843–1908</persName></name> in <date calendar="#Gregorian"
                                    when="1901">1901</date> from <name role="fmo"
                                    key="person_9985420">
                                    <persName type="display">James Ludovic Lindsay, 26th Earl of
                                        Crawford (1847–1913)</persName>
                                    <persName type="standard">Crawford, James Ludovic Lindsay, Earl
                                        of, 1847–1913</persName>
                                </name>.</p></provenance>
                        <acquisition><p>Purchased by <persName key="person_f6379" role="dnr"
                                    >Enriqueta Rylands</persName> in 1901 from
                                    <persName key="person_9985420" role="fmo"
                                    >James Ludovic Lindsay, 26th Earl of Crawford</persName>, for
                                the John Rylands Library.</p>
                            <p>Bequeathed by Enriqueta Rylands (1843–1908) in <date
                                    calendar="#Gregorian" when="1908">1908</date> to <orgName
                                    type="corporation" role="rps"
                                    ref="http://viaf.org/viaf/312795145/">John Rylands
                                    Library</orgName>.</p></acquisition>

                    </history>

                    <msContents>
                        <summary>The first volume of a five-volume set containing stories from the
                            Arabian Nights and other sources.</summary>
                        <msItem xml:id="manuscript_13834_item_1">
                            <title xml:lang="ar-Latn-x-lc" key="work_700">ʾAlf layla
                                wa-layla</title>
                            <title xml:lang="ar" type="alt">الف ليلة وليلة</title>
                            <note><p>According to Mingana, the scribe was most likely Christian
                                    because he sometimes introduces a new tale as <quote
                                        xml:lang="ar">بسم الاب والاين والروح القدس والاله
                                        الواحد</quote>ز</p></note>
                            <textLang mainLang="ar">Arabic</textLang>
                            <msItem xml:id="Arabic_MS_134-item1-item1">
                                <locus from="2b" to="29b">2b-29b</locus>
                                <title xml:lang="ar-Latn-x-lc">Ḥikayat al-tājir wa-al-jinni</title>
                                <title xml:lang="ar">حكاية التاجر والجني</title>
                                <title xml:lang="en">The Story of the Merchant and the Genie</title>
                                <note><p>Full title in manuscript: <quote xml:lang="ar">حكاية التاجر
                                            والجني وايضا الشواهد وحكاية بنت ملك كسره</quote>.</p>
                                </note>
                                <incipit>نبتدي بعون الله تعالي وحسن</incipit>
                            </msItem>
                            <msItem xml:id="Arabic_MS_134-item1-item2">
                                <locus from="31a" to="103a">31a-103a</locus>
                                <title xml:lang="en">68 tales</title>

                                <incipit>اما بعد فقد طلب مني بعض الاحبا المكر</incipit>
                                <note><p>Usually introduced by the rubricated word shahid (<quote
                                            xml:lang="ar">شاهد</quote>).</p></note>
                            </msItem>
                            <msItem xml:id="Arabic_MS_134-item1-item3">
                                <locus from="104b" to="143a">104b-143a</locus>
                                <title xml:lang="ar-Latn-x-lc">Ḥikayat bint malik Ḥusrau</title>
                                <title xml:lang="ar">حكاية بنت ملك حسره</title>
                                <title xml:lang="en">The Story of the Daugther of King
                                    Ḥusrau</title>
                                <note><p>For the other volumes of the set, see <ref
                                            target="https://www.fihrist.org.uk/catalog/manuscript_13835"
                                            >Arabic MS 135</ref> (Vol. 2), <ref
                                            target="https://www.fihrist.org.uk/catalog/manuscript_13836"
                                            >Arabic MS 136</ref> (Vol. 3), <ref
                                            target="https://www.fihrist.org.uk/catalog/manuscript_13837"
                                            >Arabic MS 137</ref> (Vol. 4), <ref
                                            target="https://www.fihrist.org.uk/catalog/manuscript_13838"
                                            >Arabic MS 138</ref> (Vol. 5).</p></note>
                            </msItem>
                        </msItem>
                    </msContents>

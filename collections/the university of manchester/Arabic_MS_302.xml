              <layoutDesc>
                <layout columns="1" writtenLines="21">Uniform layout. Broad margins. Heavily
                  rubricated in text and in margins for divisions of text and drug names.</layout>
              </layoutDesc>
            </objectDesc>
            <handDesc>
              <handNote scope="major" script="naskh">Neat Naskh script in black ink, same hand
                throughout.</handNote>
            </handDesc>
            
            <bindingDesc>
              <binding>
                <p>Leather binding on cardboard. Western binding with marbelised endsheets.
                  Identical almond-shaped medallions with symmetrical floral patterns stamped into
                  leather on front and back covers, with two flower-shaped pendants above and below
                  the central medallion, gold outlines on front and back covers. Label on spine:
                    <quote>بقية جلد سويم قانون</quote>.</p>
              </binding>
            </bindingDesc>
          </physDesc>
          <history>
            <origin>It was produced around <origDate calendar="islamic" when="1863"
                when-custom="1280">1280 AH (1863 CE)</origDate> in <origPlace key="tgn:7000208"
                >India</origPlace>. </origin>
            <provenance><p>Ownership inscription on <locus from="Flyleaf_ia">flyleaf ia</locus>:
                  <quote xml:lang="ar">بقية جلد سويم قانون في علم الطب كرنيل جارج وليم هملتن صاحب
                  بهادر</quote>.</p></provenance>
            <provenance><p>Previously in the collection of <persName type="supplied"
                  key="person_f830" role="fmo">Colonel George William Hamilton
                  (1807-1868)</persName> who served in <placeName key="tgn:7000208"
                  >India</placeName>
                <date calendar="#Gregorian" from="1823" to="1867"> from 1823 to 1867</date>, latterly
                as Commissioner of <placeName key="tgn:7001535">Delhi</placeName>. He acquired over
                a thousand Indian and Persian manuscripts, from which the <orgName type="standard"
                  key="person_134857252">British Museum</orgName> selected 352, now held in the
                  <orgName type="standard" key="person_121814978">British Library</orgName>; his
                ownership inscription on <locus from="flyleaf_ia">flyleaf ia</locus>: <quote
                  xml:lang="ar">كرنيل جارج وليم هملتن صاحب بهادر </quote> and description of the
                contents: <quote xml:lang="ar">بقية جلد سويم قانون في علم
              الطب</quote>.</p></provenance>
            <provenance><p> Formerly in the collection of <name key="person_97751058" role="fmo">
                  <persName type="display">Alexander Lindsay, 25th Earl of Crawford
                    (1812–1880)</persName>
                  <persName type="standard">Crawford, Alexander Crawford Lindsay,
                    1812-1880</persName></name>.</p>
            </provenance>
            <provenance><p>Purchased by <name role="dnr">
                  <persName type="display">Enriqueta Rylands (1843–1908)</persName>
                  <persName type="standard"> Rylands, Enriqueta, 1843–1908</persName></name> in
                  <date calendar="#Gregorian" when="1901">1901</date> from <name role="fmo"
                  key="person_9985420">
                  <persName type="display">James Ludovic Lindsay, 26th Earl of Crawford
                    (1847–1913)</persName>
                  <persName type="standard">Crawford, James Ludovic Lindsay, Earl of,
                    1847–1913</persName>
                </name>.</p></provenance>
            <acquisition when="1908">
              <p>Bequeathed by Enriqueta Rylands (1843–1908) in <date calendar="#Gregorian"
                  when="1908">1908</date> to <name role="own"><orgName
                    type="display">The John Rylands Library</orgName></name>.</p>
            </acquisition>
          </history>

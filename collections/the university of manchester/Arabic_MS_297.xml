                    <history>
                        <origin><origDate calendar="#Hijri-qamari" notBefore-custom="1203"
                                notAfter-custom="1204" notBefore="1789" notAfter="1790">1203 or 1204
                                AH (1789 or 1790 CE)</origDate></origin>
                        <provenance><p>Previously in the collection of <persName type="supplied"
                                    key="person_f830" role="fmo">Colonel George William Hamilton
                                    (1807-1868)</persName> who served in <placeName
                                    ref="http://vocab.getty.edu/page/tgn/7000208">India</placeName>
                                <date calendar="#Gregorian" from="1823" to="1867"> from 1823 to
                                    1867</date>, latterly as Commissioner of <placeName
                                    ref="http://vocab.getty.edu/page/tgn/7001535">Delhi</placeName>.
                                He acquired over a thousand Indian and Persian manuscripts, from
                                which the <orgName type="standard">British Museum</orgName> selected
                                352, now held in the <orgName type="standard">British
                                    Library</orgName>. His label on <locus from="back_paste-down"
                                    >back paste-down</locus>: <quote>Hamilton MSS 92</quote>. Note
                                on contents and date on <locus from="1a">folio 1a</locus> by
                                Hamilton.</p></provenance>
                        <provenance><p> Formerly in the collection of <name key="person_97751058"
                                    role="fmo">
                                    <persName type="display">Alexander Lindsay, 25th Earl of
                                        Crawford (1812–1880)</persName>
                                    <persName type="standard">Crawford, Alexander Crawford Lindsay,
                                        1812-1880</persName></name>. His bookplate on <locus
                                    from="back_paste-down">back paste-down</locus>:
                                    <quote>Bibliotheca Lindesiana 3/F</quote></p>
                        </provenance>
                        <provenance><p>Purchased by <name role="dnr" key="person_f6379">
                                    <persName type="display">Enriqueta Rylands
                                        (1843–1908)</persName>
                                    <persName type="standard"> Rylands, Enriqueta,
                                        1843–1908</persName></name> in <date calendar="#Gregorian"
                                    when="1901">1901</date> from <name role="fmo"
                                    key="person_9985420">
                                    <persName type="display">James Ludovic Lindsay, 26th Earl of
                                        Crawford (1847–1913)</persName>
                                    <persName type="standard">Crawford, James Ludovic Lindsay, Earl
                                        of, 1847–1913</persName>
                                </name>.</p></provenance>
                        <acquisition><p>Purchased by <persName key="person_f6379" role="dnr"
                                    change="#prov-markup">Enriqueta Rylands</persName> in 1901 from
                                    <persName key="person_9985420" role="fmo" change="#prov-markup"
                                    >James Ludovic Lindsay, 26th Earl of Crawford</persName>, for
                                the John Rylands Library.</p>
                            <p>Bequeathed by Enriqueta Rylands (1843–1908) in <date

                    <msContents>
                        <summary>The Story of Anīs al-Jalīs and Nūr al-Dīn from the Arabian Nights.
                            Written around 1750 CE. </summary>
                        <msItem xml:id="manuscript_13817-item1">
                            <title xml:lang="ar-Latn-x-lc" key="work_700">Ḥikāyat Anīs al-jalīs wa
                                Nūr al-Dīn</title>
                            <title xml:lang="ar">حكاية انيس الجليس ونور الدين</title>
                            <title xml:lang="en" type="supplied">Anis al-Jalis and Nur
                                ad-Din</title>
                            <textLang mainLang="ar">Arabic</textLang>
                            <note><p>There is no title given in the manuscript, but it contains a
                                story from the Arabian Nights: (<quote xml:lang="ar">حكابة انيس
                                    الجلبس ونور الدين</quote>).</p></note>
                        </msItem>
                    </msContents>

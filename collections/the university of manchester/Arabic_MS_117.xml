                    <history>
                        <origin><origDate calendar="#Gregorian" notBefore="1700" notAfter="1800"
                                >circa 1750</origDate></origin>
                        <provenance><p>Acquired by French orientalist <persName role="fmo"
                                    key="person_51695910">Antoine-Isaac Silvestre de
                                Sacy</persName>, (1758–1838), whose library was sold in 1843; his
                                bookplate on the <locus from="Front_paste-down">front
                                    paste-down</locus>: <quote>M. Silvestre de Sacy 183</quote>.</p>
                            <p>After de Sacy’s death, it was presumably inherited by his son Samuel
                                Ustazade Silvestre de Sacy (d. 1879), who sold many of his father's
                                oriental manuscripts through Parisian booksellers Romain Merlin
                                (1793–1871) and Grangeret de La Grange, (1790-1859) on 1843, (see
                                Bibliothèque, Vol. III, App., no. 296).</p></provenance>
                        
                        <provenance>
                            <p>Formerly part of the collection of the Persian scholar <persName
                                    type="standard" key="person_20108923" role="fmo"
                                    ref="http://viaf.org/viaf/20108923">Nathaniel Bland
                                    (1803-1865)</persName>; see label on back paste-down: Bland No.
                                196.</p></provenance>

                        <provenance><p>Bland’s oriental manuscripts were sold through <persName
                                    key="person_5679225" role="bsl">Bernard Quaritch</persName> in
                                1866 to <persName type="standard" key="person_97751058" role="fmo"
                                    >Alexander Lindsay, 25th Earl of Crawford</persName>; his
                                bookplate on the <locus from="back_paste-down">back
                                    paste-down</locus>: <quote>Bibliotheca Lindesiana
                                4/J</quote>.</p>
                        </provenance>

                        <provenance><p>Purchased by <name role="dnr" key="person_f6379">
                                    <persName type="display">Enriqueta Rylands
                                        (1843–1908)</persName>
                                    <persName type="standard"> Rylands, Enriqueta,
                                        1843–1908</persName></name> in <date calendar="#Gregorian"
                                    when="1901">1901</date> from <name role="fmo"
                                    key="person_9985420">
                                    <persName type="display">James Ludovic Lindsay, 26th Earl of
                                        Crawford (1847–1913)</persName>
                                    <persName type="standard">Crawford, James Ludovic Lindsay, Earl
                                        of, 1847–1913</persName>
                                </name>.</p></provenance>

                        <acquisition when="1908">
                            <p>Bequeathed by Enriqueta Rylands (1843–1908) in <date
                                    calendar="#Gregorian" when="1908">1908</date> to <orgName
                                    type="corporation" role="rps"
                                    ref="http://viaf.org/viaf/312795145/">John Rylands
                                    Library</orgName>.</p>
                            <p/>
                        </acquisition>

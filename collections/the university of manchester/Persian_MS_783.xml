               <msContents>
                  <summary change="#add-summary">
                     <title>Ṣawlat al-Fārūqī</title> by Muḥammad Bakhsh, poetically named Āshūb (d.
                     ca. 1784) celebrates the conquest of Iran by the Arabs in the 7th century, in a
                     style inspired by the Shahnamah. The title refers the third Sunnī caliph
                        <persName role="subject" ref="http://viaf.org/viaf/27868234"
                        key="person_27868234">‘Umar ibn al-Khaṭṭāb (ca. 584–644)</persName>, known
                     by the epithet <addName>al-Fārūq</addName> (The Distinguisher).</summary>
                  <msItem xml:id="Persian_MS_783-item1">
                     <author key="person_f5798">
                        <persName xml:lang="fa-Latn-x-lc" type="standard">Bak̲h̲sh, Muḥammad
                              <addName>Āshūb</addName>d. ca 1784</persName>; <lb/>
                        <persName xml:lang="fa">محمد بخش آشوب</persName>
                     </author>
                     <title xml:lang="ar-Latn-x-lc" key="work_7228">Ṣawlat al-Fārūqī</title>
                     <title xml:lang="fa" key="work_7228">صولة الفاروقی</title>
                     <incipit xml:lang="ar" type="basmalla"/>
                     <explicit xml:lang="ar"/>
                     <textLang mainLang="fa">Persian</textLang>
                  </msItem>
               </msContents>

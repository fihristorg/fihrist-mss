                    <history>
                        <origin/>
                        <provenance>Unidentified seals on <locus from="1a">folios 1a</locus> and
                                <locus from="21b">21b</locus>.</provenance>
                        <provenance><p>Previously in the collection of <persName type="supplied"
                                    key="person_f830" role="fmo">Colonel George William Hamilton
                                    (1807-1868)</persName> who served in <placeName
                                    key="tgn:7000208">India</placeName>
                                <date calendar="#Gregorian" from="1823" to="1867"> from 1823 to
                                    1867</date>, latterly as Commissioner of <placeName
                                    key="tgn:7001535">Delhi</placeName>. He acquired over a thousand
                                Indian and Persian manuscripts, from which the <orgName
                                    type="standard" key="viaf:134857252">British Museum</orgName>
                                selected 352, now held in the <orgName type="standard"
                                    key="viaf:121814978">British Library</orgName>; his ownership
                                inscription on <locus from="Flyleaf_iia">flyleaf iia</locus>: <quote
                                    xml:lang="ara">كرنيل جارج وليم هملتن صاحب بهادر</quote> and
                                description of the contents.</p></provenance>
                        <provenance><p>Formerly in the collection of <name key="viaf:97751058"
                                    role="fmo">
                                    <persName type="display">Alexander Lindsay, 25th Earl of
                                        Crawford (1812–1880)</persName>
                                    <persName type="standard">Crawford, Alexander Crawford Lindsay,
                                        1812-1880</persName></name>.</p>
                        </provenance>
                        <provenance><p>Purchased by <name role="dnr">
                                    <persName type="display">Enriqueta Rylands
                                        (1843–1908)</persName>
                                    <persName type="standard"> Rylands, Enriqueta,
                                        1843–1908</persName></name> in <date calendar="#Gregorian"
                                    when="1901">1901</date> from <name role="fmo" key="viaf:9985420">
                                    <persName type="display">James Ludovic Lindsay, 26th Earl of
                                        Crawford (1847–1913)</persName>
                                    <persName type="standard">Crawford, James Ludovic Lindsay, Earl
                                        of, 1847–1913</persName>
                                </name>.</p></provenance>
                        <acquisition when="1908">
                            <p>Bequeathed by Enriqueta Rylands (1843–1908) in <date
                                    calendar="#Gregorian" when="1908">1908</date> to <name
                                    key="person_152274029" role="own"><orgName type="display">The
                                        John Rylands Library</orgName></name>.</p>
                        </acquisition>

